# define order of labor statuses
for col, title in comparison_columns:

    cross = pd.crosstab(working_age[col], working_age["neet_status_compare"], values=working_age["ind_wt"], aggfunc='sum').fillna(0)

    cross_pct = cross.div(cross.sum(axis=1), axis=0) * 100
    cross_pct = cross_pct.reindex(fill_value=0)
    fig, ax = plt.subplots(figsize=(8,5))

    cross_pct.plot(kind="bar", stacked=True, colormap="Set3", ax=ax)

    for container in ax.containers:
        for bar in container:
            height = bar.get_height()
            if height > 3:
                ax.text(
                    bar.get_x() + bar.get_width() / 2,
                    bar.get_y() + height / 2,
                    f"{height:.0f}%",
                    ha='center',
                    va='center',
                    fontsize=8
                )

    ax.set_title(f"{title} (%)")
    ax.set_ylabel("Percentage (%)")
    ax.set_xlabel(title)
    ax.set_ylim(0, 100)

    plt.xticks(rotation=30, ha='right')
    ax.legend(title="Labor Status", bbox_to_anchor=(1.02, 1), loc="upper left")

    plt.tight_layout()

    # save each plot
    fn = safe_filename(title)
    fig.savefig(f"neetvsnonneet/{fn}.png")

    plt.close(fig)
