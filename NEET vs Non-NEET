neet_only["age_group"] = pd.cut(
   neet_only["q01_03"],
   bins=[14, 24, 45, 64],
   labels=["15-24", "25-45", "46-64"])

neet_only["school_status"] = neet_only["q07_04"].map(school_map)

neet_age_edu_pct = pd.crosstab(neet_only["age_group"], neet_only["school_status"], values=neet_only["ind_wt"], aggfunc='sum', normalize="index") * 100

# CHILDERN

# Identify children aged 0–3 in personal dataset
personal["child_0_3"] = personal["q01_03"].between(0, 3)

# Aggregate at household level to see if any child 0–3 exists
hh_child03 = (personal.groupby(["psu_number", "hh_number"])["child_0_3"].any().reset_index().rename(columns={"child_0_3": "hh_has_child_0_3"}))

# Merge this info into working_age dataframe
working_age = pd.merge(working_age, hh_child03, on=["psu_number", "hh_number"], how="left")

# Filter NEETs and calculate percentage with child 0–3
neet_only = working_age[working_age["neet_status"]]
neet03percentages = (neet_only.groupby("hh_has_child_0_3")["ind_wt"].sum() / neet_only["ind_wt"].sum() * 100)

#Flag children under 18
personal["child_under18"] = personal["q01_03"] < 18

# Count number of children under 18 per household
hh_child18 = (personal.groupby(["psu_number", "hh_number"])["child_under18"].sum().reset_index().rename(columns={"child_under18": "hh_children_count"}))
working_age = pd.merge(working_age, hh_child18, on=["psu_number", "hh_number"], how="left")
