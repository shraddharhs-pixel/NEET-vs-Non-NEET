print("\nEmployment classification (%): ")
print(compare_characteristics(working_age, "classify1"))

print("\nrural/urban comparison (%): ")
print(compare_characteristics(working_age, "ad_4"))

print("\npoor/non-poor comparison (%): ")
print(compare_characteristics(working_age, "poor"))

print("\nNEET vs Non-NEET within Asset Quintile (%):")
print(neet_within_quintile(working_age, "asset_quintile"))

print("\nNEET vs Non-NEET within Remittance Quintile (%):")
print(neet_within_quintile(working_age, "remittance_quintile"))

print("\nNEET vs Non-NEET within PCEP Quintile (%):")
