# Determine NEETs who are likely to have children
working_age["neet_has_children"] = working_age.apply(
   lambda row: True
       if (row["neet_status"]
           and row["q01_05"] != "Never married"
           and row["q01_04"] in ["HEAD", "HUSBAND", "WIFE"]
           and row["hh_children_count"] > 0)
       else False,
   axis=1)

# Calculate percentage of NEETs likely to have children
neet_only = working_age[working_age["neet_status"]]
childrenpercentages = (neet_only.groupby("neet_has_children")["ind_wt"].sum() /neet_only["ind_wt"].sum() * 100)

# DEFINE COMPARISON GROUPS
def get_detailed_status(row):
    if row["neet_status"]:
        return "NEET"
    return "Non-NEET"

working_age["labor_status_compare"] = working_age.apply(get_detailed_status, axis=1)

# COMPARISON FUNCTION
def compare_characteristics(df, characteristic_col):
    counts = df.groupby(["labor_status_compare", characteristic_col])["ind_wt"].sum().unstack()
    percentages = counts.div(counts.sum(axis=1), axis=0) * 100
    return percentages.round(1)

def neet_within_quintile(df, quintile_col):
    counts = df.groupby([quintile_col, "labor_status_compare"])["ind_wt"].sum().unstack()
    percentages = counts.div(counts.sum(axis=1), axis=0) * 100
    return percentages.round(1)

print ("\nCOMPARISON TABLE")

print("\nMarital Status Comparison (%):")
print(compare_characteristics(working_age, "q01_05"))

print("\nGender comparison (%):")
